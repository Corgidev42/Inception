# Inception - Environment Variables
# Copy this file to .env and fill in your values
# NEVER commit .env or secrets to git!

LOGIN_NAME=your_login
DOMAIN_NAME=your_login.42.fr
SITE_TITLE=Inception

# Data directory
# - 42 VM/Linux: /home/your_login/data
# - Mac (dev local): /Users/votre_user/data (ex: /Users/dev/data)
DATA_DIR=/home/your_login/data

# FTP passif : même adresse que dans FileZilla (127.0.0.1 en local, IP publique de la VM en défense)
FTP_PASV_ADDRESS=127.0.0.1

# Database
SQL_DATABASE=wordpress
SQL_USER=wp_user
SQL_PASSWORD_FILE=/run/secrets/db_password
SQL_ROOT_PASSWORD_FILE=/run/secrets/db_root_password

# WordPress Admin (username must NOT contain admin/administrator)
ADMIN_USER=site_owner
ADMIN_PASSWORD_FILE=/run/secrets/wp_admin_password
ADMIN_EMAIL=admin@42.fr

# WordPress regular user
USER_LOGIN=wp_user
USER_PASS_FILE=/run/secrets/wp_user_password
USER_EMAIL=user@student.42.fr
